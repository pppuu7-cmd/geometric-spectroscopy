# =========================================================
# Python / Packaging (build artifacts)
# =========================================================
__pycache__/
*.py[cod]
*$py.class

# Wheels / sdists / build dirs
dist/
build/
*.egg
*.egg-info/
.eggs/
pip-wheel-metadata/
*.whl
*.tar.gz

# PEP 517 / build backends temp
*.manifest
*.spec

# Local editable installs / metadata
**/*.egg-info/
**/*.dist-info/

# Temporary folders produced by sdist (projectname-version/)
geometric_spectroscopy-*/
# (если имя проекта поменяется — можно расширить правилом ниже)
# *-*/

